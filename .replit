modules = ["nodejs-24"]

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/mockup-sandbox"

  [deployment]
  deploymentTarget = "autoscale"

  [deployment.build]
  args = ["bash", "-c", "PORT=3001 pnpm --filter @workspace/api-server run build"]

  [deployment.run]
  args = ["bash", "-c", "PORT=$PORT node artifacts/api-server/dist/index.cjs"]

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
  runButton = "Project"

  [agent]
  stack = "PNPM_WORKSPACE"
  expertMode = true

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000
  